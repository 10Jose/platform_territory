DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/db_transformation
INGESTION_BASE_URL=http://localhost:8001
INGESTION_LATEST_PATH=/datasets/latest
INGESTION_DOWNLOAD_TEMPLATE=/datasets/{dataset_id}/download
TRANSFORMATION_RULES_VERSION=1.0.0

# Contrato esperado de ms-ingestion:
# GET {INGESTION_BASE_URL}{INGESTION_LATEST_PATH} -> JSON con "id" del último dataset
# GET .../datasets/{id}/download -> cuerpo del CSV (ajusta INGESTION_DOWNLOAD_TEMPLATE)
